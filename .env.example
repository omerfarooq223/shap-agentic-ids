# SHAP-Explained Agentic IDS Configuration
# Copy this to .env and fill in your actual API keys

# ============================================================================
# GROQ API Key (Required for LLM-based threat classification)
# ============================================================================
# Get free key at: https://console.groq.com/keys
# Free tier: 100K tokens/day (sufficient for ~250K flows with 400 tokens per flow)
# Fallback: If missing, system uses heuristic threat classification (entropy + port-based)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# AbuseIPDB API Key (Required for IP reputation checks)
# ============================================================================
# Get free key at: https://www.abuseipdb.com/register
# Free tier: 1000 requests/day
# Fallback: If missing, IP reputation checks are disabled
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ============================================================================
# Flask Configuration
# ============================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5005

# ============================================================================
# Security - Internal API Key (CRITICAL: REQUIRED for production)
# ============================================================================
# IMPORTANT: You MUST set this to a strong, random secret before deploying.
# This key controls access to /detect, /chat, and other privileged endpoints.
# The system will FAIL TO START if this is not set to a 32+ character value.
# 
# Generate a strong key with: openssl rand -hex 32
# This will output something like:
#   a3f8c2e9d1b4f7a6c5e8d9f2a1b3c4e5d6f7a8b9c0d1e2f3a4b5c6d7e8f9a0
# 
# For development ONLY:
#   - You MUST manually set this before running the Flask server
#   - Never use the same key in multiple environments
# 
# For production ONLY:
#   - Use a 32+ character cryptographically secure random string
#   - Store in a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
#   - Rotate the key regularly
#   - Use different keys for different environments (dev, staging, prod)
INTERNAL_API_KEY=

# ============================================================================
# Network / Packet Capture
# ============================================================================
# Network interface for live Scapy packet capture (macOS: en0, Linux: eth0)
CAPTURE_INTERFACE=en0

# ============================================================================
# API Timeouts (seconds)
# ============================================================================
API_TIMEOUT=10
MAX_RETRIES=3

# ============================================================================
# Rate Limiting Configuration (prevents DOS attacks)
# ============================================================================
# Enable/disable rate limiting (set to 'false' for development/testing only)
RATE_LIMIT_ENABLED=true

# Detection endpoint rate limit (anomaly detection is computationally expensive)
# Format: "requests per time_unit" (e.g., "100 per minute", "1000 per hour")
RATE_LIMIT_DETECT=100 per minute

# Chat endpoint rate limit (LLM calls are expensive and slow)
RATE_LIMIT_CHAT=50 per minute

# Health check rate limit (frequent monitoring is expected)
RATE_LIMIT_HEALTH=1000 per minute

# ============================================================================
# CORS Configuration (Frontend Origin) - REQUIRED
# ============================================================================
# CRITICAL: You MUST specify your frontend domain(s).
# This restricts API access to only your approved frontend(s).
# 
# For production: Never use '*' (wildcard) — it allows ANY website to steal API access
# For development: You can use http://localhost:5173 (Vite) or http://localhost:3000 (React)
# 
# Examples:
#   https://myapp.com
#   https://dashboard.example.com
#   http://localhost:5173
# 
# Multiple origins separated by commas (if supported):
#   https://myapp.com,https://staging.myapp.com
FRONTEND_ORIGIN=

# ============================================================================
# Environment Configuration
# ============================================================================
# Set to 'production' to enforce security checks (CORS wildcards not allowed)
# Set to 'development' for relaxed security (localhost allowed)
ENVIRONMENT=development

# ============================================================================
# SSL/TLS Configuration (for HTTPS support)
# ============================================================================
# For production HTTPS, either:
# 1. Provide certificate and key files:
#    SSL_CERT_FILE=/etc/ssl/certs/myapp.pem
#    SSL_KEY_FILE=/etc/ssl/private/myapp.key
# 
# 2. Or run behind a reverse proxy (recommended for production):
#    nginx, Caddy, or other reverse proxy handles TLS termination
#    Flask runs on HTTP behind the proxy
# 
# Example self-signed certificate (development only):
#    openssl req -x509 -newkey rsa:4096 -nodes -out cert.pem -keyout key.pem -days 365
# 
# Note: In production, ALWAYS use a valid certificate from a trusted CA
#       (e.g., Let's Encrypt, AWS ACM, etc.)
#SSL_CERT_FILE=
#SSL_KEY_FILE=

# ============================================================================
# Model Training Configuration
# ============================================================================
# SMOTE Strategy: Controls synthetic minority sample generation ratio
# 
# SMOTE_STRATEGY defines the minority/majority class ratio after resampling:
#   - 0.25: Conservative (default) - 1 minority sample per 4 majority samples
#   - 0.5:  Moderate - 1 minority sample per 2 majority samples
#   - 0.75: Aggressive - 3 minority samples per 4 majority samples
#   - 1.0:  Extreme - Equal classes (risks overfitting)
# 
# Why 0.25 (default)?
#   - Empirically validated on CICIDS2017 (99% benign baseline)
#   - Balances recall without excessive synthetic data
#   - Reference: Chawla et al. 2002 SMOTE, Sharafaldin et al. 2017 IDS benchmarks
#   - Values > 0.5 harm generalization (too much synthetic data)
#   - Values < 0.1 provide insufficient minority class samples
# 
# Note: Train/Val/Test split is hardcoded as 60/20/20 for proper evaluation
#       - Training (60%): Used with SMOTE for class balancing
#       - Validation (20%): Used for hyperparameter tuning/early stopping
#       - Test (20%): Final held-out evaluation (never touched during training)
# 
SMOTE_STRATEGY=0.25

# ============================================================================
# Threat Classification Thresholds (Data-Driven, not magic numbers)
# ============================================================================
# These thresholds control threat classification logic and risk scoring.
# All values are configurable via environment variables (with sensible defaults).
#
# Threat Intelligence (AbuseIPDB)
#   ABUSEIPDB_HIGH_CONFIDENCE_THRESHOLD: If abuse_score > this, skip LLM (use direct conclusion)
#     Default: 80 (high confidence in external reputation)
#   ZERO_DAY_ML_CONFIDENCE_THRESHOLD: If ML confidence > this AND abuse_score is clean
#     Default: 0.90 (potential zero-day signal)
#   ZERO_DAY_ABUSE_SCORE_CLEAN_THRESHOLD: Considered "clean" if abuse_score < this
#     Default: 10 (low reputation score)
#
# Risk Scoring Thresholds (used in final alert recommendation)
#   RISK_SCORE_CRITICAL_THRESHOLD: If risk_score > this, recommend CRITICAL action
#     Default: 8.0 (on scale 0-10)
#   RISK_SCORE_WARNING_THRESHOLD: If risk_score > this, recommend WARNING action
#     Default: 5.0 (on scale 0-10)
#
# LLM Confidence Defaults
#   DEFAULT_LLM_CONFIDENCE: Default confidence if LLM response doesn't include one
#     Default: 0.5
#   FALLBACK_LLM_CONFIDENCE: Confidence used if LLM API fails
#     Default: 0.3 (lower than default since we're using fallback)
#
ABUSEIPDB_HIGH_CONFIDENCE_THRESHOLD=80
ZERO_DAY_ML_CONFIDENCE_THRESHOLD=0.90
ZERO_DAY_ABUSE_SCORE_CLEAN_THRESHOLD=10
RISK_SCORE_CRITICAL_THRESHOLD=8.0
RISK_SCORE_WARNING_THRESHOLD=5.0
DEFAULT_LLM_CONFIDENCE=0.5
FALLBACK_LLM_CONFIDENCE=0.3
