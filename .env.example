# SHAP-Explained Agentic IDS Configuration
# Copy this to .env and fill in your actual API keys

# ============================================================================
# GROQ API Key (Required for LLM-based threat classification)
# ============================================================================
# Get free key at: https://console.groq.com/keys
# Free tier: 100K tokens/day (sufficient for ~250K flows with 400 tokens per flow)
# Fallback: If missing, system uses heuristic threat classification (entropy + port-based)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=mixtral-8x7b-32768

# ============================================================================
# AbuseIPDB API Key (Required for IP reputation checks)
# ============================================================================
# Get free key at: https://www.abuseipdb.com/register
# Free tier: 1000 requests/day
# Fallback: If missing, IP reputation checks are disabled
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
ABUSEIPDB_API_URL=https://api.abuseipdb.com/api/v2/check

# ============================================================================
# Flask Configuration
# ============================================================================
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# ============================================================================
# API Timeouts (seconds)
# ============================================================================
API_TIMEOUT=10
MAX_RETRIES=3
RETRY_BACKOFF=0.5
