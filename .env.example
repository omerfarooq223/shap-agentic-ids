# SHAP-Explained Agentic IDS Configuration

# Groq API Key (Required for agentic reasoning layer)
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# AbuseIPDB API Key (Required for threat intelligence verification)
# Get your free key at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Flask Configuration (Optional)
FLASK_ENV=development
FLASK_DEBUG=False

# API Endpoints (Optional, for testing)
# API_TIMEOUT=10
